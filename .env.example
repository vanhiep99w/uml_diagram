# Database
# For local Dolt DB (connection_limit=5 because Dolt has lower max_connections):
DATABASE_URL="mysql://user:password@localhost:3306/uml_diagram?connection_limit=5"

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Encryption for API keys (AES-256)
# Must be exactly 32 characters
ENCRYPTION_KEY="your-32-character-encryption-key"

# OpenAI (optional - users can provide their own via settings)
OPENAI_API_KEY=""
